{
  "name": "collapse-engine",
  "version": "1.0.0",
  "description": "Adaptive workflow engine powered by Notion MCP — failure-aware system for real-world instability",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "test": "jest --testPathPattern=tests/",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js"],
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
